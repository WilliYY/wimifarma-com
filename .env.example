# Mantem o servico agente em sombra. false nao afeta a resposta do chat.
MIAUW_AGENT_SHADOW_ON_SEND=false
MIAUW_AGENT_SHADOW_TIMEOUT_MS=12000
# Motor do Miauby: php, node_shadow ou node. Use node so com usuarios liberados.
MIAUW_ENGINE=php
MIAUW_AGENT_ENGINE_ALLOWED_USERS=adm
# Bloqueia envio para usuarios comuns durante troca do motor; adm fica liberado por padrao.
MIAUW_MAINTENANCE_MODE=false
